# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=http://YOUR_DROPLET_IP
SECRET_KEY=change-me-to-a-long-random-string

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=transcriptions
POSTGRES_PASSWORD=change-me
POSTGRES_DB=transcriptions
DATABASE_URL=postgresql://transcriptions:change-me@postgres:5432/transcriptions

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=quickstart-1600776214159
GCP_BUCKET_NAME=cachiai-recordings
GCP_RECORDINGS_PREFIX=recordings/
GCP_BUCKET_LOCATION=EU
# Paste the full JSON content of your service account key (single line, escaped)
GCP_SERVICE_ACCOUNT_JSON=

# ─── Pub/Sub Webhook Auth ─────────────────────────────────────────────────────
# Email of the GCP service account that Pub/Sub uses to sign OIDC tokens
PUBSUB_SERVICE_ACCOUNT_EMAIL=
# Shared secret fallback (used in X-Webhook-Secret header for testing)
WEBHOOK_SECRET=change-me-webhook-secret

# ─── AssemblyAI ───────────────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_MODEL=universal-3-pro
ASSEMBLYAI_SPEAKER_DIARIZATION=true
# Secret sent in X-AssemblyAI-Secret header on callbacks
ASSEMBLYAI_WEBHOOK_SECRET=change-me-assemblyai-secret
ASSEMBLYAI_SPEAKERS_EXPECTED=2          # set to 0 to let AssemblyAI auto-detect speaker count

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Model for call summaries — falls back through list on failure
OPENAI_SUMMARY_MODEL=gpt-5.2
OPENAI_FALLBACK_MODELS=gpt-5,gpt-5-mini,gpt-4o
# Model for speaker re-classification — leave blank to use OPENAI_SUMMARY_MODEL
OPENAI_SPEAKER_MODEL=
# Confidence threshold for speaker labels (0.0–1.0)
# Below this value, neutral "Speaker A/B" labels are used instead of "Likely Agent/Customer"
SPEAKER_CONFIDENCE_THRESHOLD=0.75

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Gmail account that sends emails
GMAIL_ADDRESS=you@gmail.com
# 16-character App Password: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=
# Display name in the From header
EMAIL_FROM_NAME=3CX Transcriptions
REPLY_TO_EMAIL=
ADMIN_EMAIL=admin@yourdomain.com

# ─── Behaviour ────────────────────────────────────────────────────────────────
MAX_RETRIES=4
DELETE_TEMP_FILES=true
STORE_TRANSCRIPTS=false
DEBUG_MODE=false
